# API
PORT=3001
MONGO_URL=mongodb://localhost:27017/http-monitor
HTTPBIN_URL=https://httpbin.org/anything
POLL_CRON=*/5 * * * *
POLL_ON_START=true
REQUEST_TIMEOUT_MS=10000
CORS_ORIGIN=*
LOG_LEVEL=info

# LLM insights (Option B) — leave ANTHROPIC_API_KEY empty to run in fallback mode
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_CALLS_PER_HOUR=20

# Anomaly detection tuning (defaults shown). Lower these to trigger an incident on
# demand — e.g. for a live demo set ANOMALY_THRESHOLD_RATIO=1.2, ANOMALY_MIN_SAMPLES=1,
# INCIDENT_COOLDOWN_MINUTES=0. Restore the defaults afterwards.
ANOMALY_THRESHOLD_RATIO=2
ANOMALY_CRITICAL_RATIO=3
ANOMALY_MIN_SAMPLES=5
INCIDENT_COOLDOWN_MINUTES=15

# Web (Vite)
VITE_API_URL=http://localhost:3001
